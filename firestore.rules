rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // スケジュールの読み取りは認証済みユーザーのみ
    match /schedules/{scheduleId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
      
      // 参加者の読み取り/書き込みは認証済みユーザーのみ
      match /participants/{participantId} {
        allow read: if request.auth != null;
        // 自分自身のドキュメントのみ作成可能（IDはUID固定、userIdも一致）
        allow create: if request.auth != null
                      && request.auth.uid == participantId
                      && request.auth.uid == request.resource.data.userId;
        // 自分自身のデータのみ更新可能（既存 or 更新後の userId が自分）
        allow update: if request.auth != null
                      && (request.auth.uid == resource.data.userId || request.auth.uid == request.resource.data.userId)
                      && request.auth.uid == participantId;
        // 自分自身のデータのみ削除可能
        allow delete: if request.auth != null 
                      && request.auth.uid == resource.data.userId
                      && request.auth.uid == participantId;
      }
    }
    
    // その他のドキュメントは認証済みユーザーのみアクセス可能
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
